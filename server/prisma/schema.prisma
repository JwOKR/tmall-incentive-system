// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 系统用户（登录）
model User {
  id          String   @id @default(cuid())
  username    String   @unique // 用户名
  password    String   // bcrypt加密密码
  role        String   @default("admin") // admin, user
  permissions String?  @db.Text // JSON格式权限: {orders:{view:true,edit:true}, takers:{view:true,edit:false}, ...}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  logs        Log[]

  @@map("users")
}

// 接单人管理
model OrderTaker {
  id          String   @id @default(cuid())
  wechatName  String   // 微信昵称
  wechatId    String   @unique // 微信号
  status      String   @default("active") // active, inactive, suspended
  totalOrders Int      @default(0)
  totalAmount Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  
  orders      Order[]
  
  @@index([status])
  @@map("order_takers")
}

// 任务管理（发布任务）
model Task {
  id              String   @id @default(cuid())
  publishDate     DateTime @default(now()) // 发布日期
  productId       String   // 商品ID
  productCode     String   // 产品编号
  taoToken        String?  @unique // 淘口令（唯一，空白时允许多条）
  price           Float    // 商品价格
  baseCommission  Float    @default(5) // 基础佣金，默认5元
  reviewReward    Float    @default(0) // 晒单奖励
  maxOrders       Int      @default(1) // 限接人数，默认1人
  currentOrders   Int      @default(0) // 已接人数
  status          String   @default("pending") // pending待接单, active进行中, refunded已返款, completed已完成, cancelled已取消
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())
  
  orders          Order[]
  
  @@index([status])
  @@index([productId])
  @@index([productCode])
  @@map("tasks")
}

// 订单明细（接单后自动生成）
model Order {
  id                  String    @id @default(cuid())
  orderDate           DateTime  @default(now()) // 接单日期
  taskId              String?   // 关联任务（可选）
  takerId             String?   // 接单人（可选）
  
  // 商品信息
  productId           String    // 商品ID
  productCode         String    // 产品编号
  
  // 订单信息
  orderNo19           String?   @unique // 19订单号（公司内部订单号，唯一）
  orderNo             String?   @unique // 订单编号（淘宝订单号，唯一）
  orderLink           String?   // 订单链接
  actualPayment       Float     @default(0) // 实付金额
  
  // 返款信息
  totalRefund         Float     @default(0) // 总返款
  isRefunded          Boolean   @default(false) // 是否已返款
  refundDate          DateTime? // 返款日期
  
  // 好评信息
  isGoodReview        String    @default("pending") // 好评状态: pending未好评, reviewed已好评, creating作图中, returned已返图
  baseCommission      Float     @default(5) // 基础返佣，默认5元
  reviewCommission    Float     @default(0) // 好评返佣
  reviewCommissionDate DateTime? // 好评返佣日期
  
  remark              String?   // 备注
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @default(now())
  
  task                Task?     @relation(fields: [taskId], references: [id])
  taker               OrderTaker? @relation(fields: [takerId], references: [id])
  logs                Log[]
  
  @@index([orderDate])
  @@index([takerId])
  @@index([taskId])
  @@index([isRefunded])
  @@index([isGoodReview])
  @@index([productId])
  @@index([productCode])
  @@map("orders")
}

// 操作日志
model Log {
  id          String   @id @default(cuid())
  orderId     String?
  userId      String?
  action      String   // create, update, delete, status_change
  detail      String
  ipAddress   String?
  createdAt   DateTime @default(now())
  
  order       Order?   @relation(fields: [orderId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
  
  @@index([orderId])
  @@index([action])
  @@index([createdAt])
  @@map("logs")
}

// 系统设置（KV存储）
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique // 设置键名，如 ai_api_url
  value     String   // 设置值
  group     String   @default("general") // 分组：general, ai
  label     String?  // 显示名称
  updatedAt DateTime @default(now())

  @@index([key])
  @@index([group])
  @@map("system_settings")
}

// 回头客立减（每天一条，两组人群）
model RepeatDiscount {
  id              String   @id @default(cuid())
  recordDate      DateTime @unique // 记录日期（每天唯一）

  // 近2年已购用户人群
  g1GrantAmount   Float    @default(0) // 发放金额（元）
  g1PaymentAmount Float    @default(0) // 支付金额（元）
  g1PaymentBuyers Int      @default(0) // 支付买家数（人）
  g1PaymentItems  Int      @default(0) // 支付件数（件）

  // 365天内有购买且60天无购买人群
  g2GrantAmount   Float    @default(0) // 发放金额（元）
  g2PaymentAmount Float    @default(0) // 支付金额（元）
  g2PaymentBuyers Int      @default(0) // 支付买家数（人）
  g2PaymentItems  Int      @default(0) // 支付件数（件）

  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())

  @@index([recordDate])
  @@map("repeat_discounts")
}

// AI分析结果存储（持久化）
model RepeatDiscountAnalysis {
  id        String   @id @default(cuid())
  type      String   // 'daily' | 'overall'
  recordId  String?  // 单日分析关联的记录ID
  scopeKey  String   @unique // daily: recordId; overall: "startDate_endDate" or "all_all"
  sections  String   @db.Text // JSON string of [{ title, content }]
  source    String   // 'ai' | 'local'
  model     String?  // AI模型名称
  rawText   String?  @db.Text // AI原始返回文本
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@index([type, scopeKey])
  @@map("repeat_discount_analyses")
}